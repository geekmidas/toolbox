PORT=3000
NODE_ENV=development

# Primary database
DATABASE_URL=postgresql://geekmidas:geekmidas@localhost:5432/kitchen_sink

# Events / queues run on pg-boss locally (reuses the same Postgres, own schema).
# Topic publisher (EventsService) writes here; subscribers + queue workers poll here.
EVENT_PUBLISHER_CONNECTION_STRING=pgboss://geekmidas:geekmidas@localhost:5432/kitchen_sink?schema=pgboss
EVENT_SUBSCRIBER_CONNECTION_STRING=pgboss://geekmidas:geekmidas@localhost:5432/kitchen_sink?schema=pgboss

# Per-queue producer connection string (one per queue, name-namespaced).
# `emails` queue → EMAILS_PUBLISHER_CONNECTION_STRING. Locally this is pg-boss;
# deployed, infra injects an sqs:// string for the same variable.
EMAILS_PUBLISHER_CONNECTION_STRING=pgboss://geekmidas:geekmidas@localhost:5432/kitchen_sink?schema=pgboss

# Auth (mock) — see src/services/AuthService.ts
JWT_SECRET=dev-secret
JWT_ISSUER=kitchen-sink

# Storage (S3). Point at LocalStack/MinIO for local dev, or leave defaults to
# generate presigned URLs without a live bucket.
STORAGE_BUCKET=kitchen-sink-uploads
STORAGE_REGION=us-east-1
