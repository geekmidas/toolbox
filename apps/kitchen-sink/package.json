{
	"name": "@geekmidas/kitchen-sink",
	"version": "0.0.2",
	"private": true,
	"type": "module",
	"description": "Kitchen-sink example exercising every @geekmidas/toolbox integration point: endpoints, functions, crons, subscribers, queues, services/DI, storage, cache, audit, events, telescope, studio and OpenAPI.",
	"scripts": {
		"dev": "gkm dev",
		"build": "gkm build --providers server,aws-apigatewayv2",
		"start": "node .gkm/server/app.js",
		"openapi": "gkm openapi",
		"migrate": "tsx src/migrate.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "~3.844.0",
		"@aws-sdk/s3-presigned-post": "^3.844.0",
		"@aws-sdk/s3-request-presigner": "~3.844.0",
		"@geekmidas/audit": "workspace:*",
		"@geekmidas/cache": "workspace:*",
		"@geekmidas/cli": "workspace:*",
		"@geekmidas/constructs": "workspace:*",
		"@geekmidas/db": "workspace:*",
		"@geekmidas/envkit": "workspace:*",
		"@geekmidas/errors": "workspace:*",
		"@geekmidas/events": "workspace:*",
		"@geekmidas/logger": "workspace:*",
		"@geekmidas/services": "workspace:*",
		"@geekmidas/storage": "workspace:*",
		"@geekmidas/studio": "workspace:*",
		"@geekmidas/telescope": "workspace:*",
		"@hono/node-server": "~1.19.5",
		"hono": "^4.7.15",
		"kysely": "~0.29.4",
		"pg": "~8.16.0",
		"pino": "^9.6.0",
		"zod": "~4.1.13"
	},
	"devDependencies": {
		"@types/node": "~24.9.1",
		"@types/pg": "~8.15.0",
		"tsx": "~4.20.6"
	}
}
