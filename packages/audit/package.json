{
	"name": "@geekmidas/audit",
	"version": "2.1.0",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./kysely": {
			"import": {
				"types": "./dist/kysely.d.mts",
				"default": "./dist/kysely.mjs"
			},
			"require": {
				"types": "./dist/kysely.d.cts",
				"default": "./dist/kysely.cjs"
			}
		},
		"./memory": {
			"import": {
				"types": "./dist/memory.d.mts",
				"default": "./dist/memory.mjs"
			},
			"require": {
				"types": "./dist/memory.d.cts",
				"default": "./dist/memory.cjs"
			}
		},
		"./cache": {
			"import": {
				"types": "./dist/cache.d.mts",
				"default": "./dist/cache.mjs"
			},
			"require": {
				"types": "./dist/cache.d.cts",
				"default": "./dist/cache.cjs"
			}
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/geekmidas/toolbox"
	},
	"publishConfig": {
