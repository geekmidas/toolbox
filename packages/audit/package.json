		"@geekmidas/schema": "workspace:^",
		"kysely": ">=0.28.2 <0.30.0"
	},
	"peerDependenciesMeta": {
		"@geekmidas/cache": {
			"optional": true
		},
		"@geekmidas/schema": {
			"optional": true
		},
		"kysely": {
			"optional": true
		}
	},
	"devDependencies": {
		"@geekmidas/cache": "workspace:^",
		"@geekmidas/schema": "workspace:^",
		"kysely": "~0.29.4",
		"pg": "~8.16.0",
		"@types/pg": "~8.15.6"
	}
