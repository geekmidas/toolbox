{
	"name": "@geekmidas/auth",
	"version": "2.0.1",
	"description": "JWT and OIDC authentication with token verification, Hono middleware, and Lambda authorizers",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./server": {
			"import": {
				"types": "./dist/server.d.mts",
				"default": "./dist/server.mjs"
			},
			"require": {
				"types": "./dist/server.d.cts",
				"default": "./dist/server.cjs"
			}
		},
		"./client": {
			"import": {
				"types": "./dist/client.d.mts",
				"default": "./dist/client.mjs"
			},
			"require": {
				"types": "./dist/client.d.cts",
				"default": "./dist/client.cjs"
			}
		},
		"./jwt": {
			"import": {
				"types": "./dist/jwt.d.mts",
				"default": "./dist/jwt.mjs"
			},
			"require": {
				"types": "./dist/jwt.d.cts",
				"default": "./dist/jwt.cjs"
			}
		},
		"./hono/jwt": {
			"import": {
				"types": "./dist/hono/jwt.d.mts",
				"default": "./dist/hono/jwt.mjs"
			},
			"require": {
				"types": "./dist/hono/jwt.d.cts",
				"default": "./dist/hono/jwt.cjs"
			}
		},
		"./lambda/jwt": {
			"import": {
				"types": "./dist/lambda/jwt.d.mts",
				"default": "./dist/lambda/jwt.mjs"
			},
			"require": {
				"types": "./dist/lambda/jwt.d.cts",
				"default": "./dist/lambda/jwt.cjs"
			}
		},
		"./oidc": {
			"import": {
				"types": "./dist/oidc.d.mts",
				"default": "./dist/oidc.mjs"
			},
			"require": {
				"types": "./dist/oidc.d.cts",
				"default": "./dist/oidc.cjs"
			}
		},
		"./hono/oidc": {
			"import": {
				"types": "./dist/hono/oidc.d.mts",
				"default": "./dist/hono/oidc.mjs"
			},
			"require": {
				"types": "./dist/hono/oidc.d.cts",
				"default": "./dist/hono/oidc.cjs"
			}
		},
		"./lambda/oidc": {
			"import": {
				"types": "./dist/lambda/oidc.d.mts",
				"default": "./dist/lambda/oidc.mjs"
			},
			"require": {
				"types": "./dist/lambda/oidc.d.cts",
				"default": "./dist/lambda/oidc.cjs"
			}
		}
	},
	"scripts": {
		"play": "tsx src/playground.ts"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/geekmidas/toolbox"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"dependencies": {
		"@openauthjs/openauth": "~0.4.3",
		"jose": "~5.10.0",
		"jsonwebtoken": "^9.0.2",
		"@types/ms": "~2.1.0"
	},
	"devDependencies": {
		"@geekmidas/cache": "workspace:^",
		"@types/jsonwebtoken": "^9.0.5"
	},
	"peerDependencies": {
		"@geekmidas/cache": "workspace:^",
		"@types/aws-lambda": ">=8.10.92",
		"hono": ">=4.0.0"
	},
	"peerDependenciesMeta": {
		"@geekmidas/cache": {
			"optional": true
		},
		"@types/aws-lambda": {
			"optional": true
		},
		"hono": {
			"optional": true
		}
	}
}
