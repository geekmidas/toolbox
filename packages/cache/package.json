{
	"name": "@geekmidas/cache",
	"version": "1.1.0",
	"description": "Unified cache interface with multiple storage implementations",
	"private": false,
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./memory": {
			"import": {
				"types": "./dist/memory.d.mts",
				"default": "./dist/memory.mjs"
			},
			"require": {
				"types": "./dist/memory.d.cts",
				"default": "./dist/memory.cjs"
			}
		},
		"./upstash": {
			"import": {
				"types": "./dist/upstash.d.mts",
				"default": "./dist/upstash.mjs"
			},
			"require": {
				"types": "./dist/upstash.d.cts",
				"default": "./dist/upstash.cjs"
			}
		},
		"./expo": {
			"import": {
				"types": "./dist/expo.d.mts",
				"default": "./dist/expo.mjs"
			},
			"require": {
				"types": "./dist/expo.d.cts",
				"default": "./dist/expo.cjs"
			}
		},
		"./file": {
			"import": {
				"types": "./dist/file.d.mts",
				"default": "./dist/file.mjs"
			},
			"require": {
				"types": "./dist/file.d.cts",
				"default": "./dist/file.cjs"
			}
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/geekmidas/toolbox"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"dependencies": {
		"date-fns": "~4.1.0",
		"proper-lockfile": "^4.1.2"
	},
	"peerDependencies": {
		"@upstash/redis": "~1.35.1",
		"expo-secure-store": "^14.2.3"
	},
	"devDependencies": {
		"@types/proper-lockfile": "^4.1.4"
	}
}
