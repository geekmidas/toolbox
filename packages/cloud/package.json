{
	"name": "@geekmidas/cloud",
	"version": "1.0.1",
	"type": "module",
	"files": [
		"dist",
		"src/sst"
	],
	"scripts": {
		"sst:install": "sst install",
		"ts:check:sst": "tsc --noEmit -p src/sst/tsconfig.json 2>&1 | grep -E 'src/sst/.*error TS' && exit 1 || exit 0"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./utils": {
			"import": {
				"types": "./dist/utils/index.d.mts",
				"default": "./dist/utils/index.mjs"
			},
			"require": {
				"types": "./dist/utils/index.d.cts",
				"default": "./dist/utils/index.cjs"
			}
		},
		"./sst": "./src/sst/index.ts"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/geekmidas/toolbox"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"dependencies": {
		"@geekmidas/envkit": "workspace:*",
		"@geekmidas/manifest": "workspace:*",
		"lodash.snakecase": "~4.1.1"
	},
	"devDependencies": {
		"@types/lodash.get": "~4.4.9",
		"@types/lodash.set": "~4.3.9",
		"@types/lodash.snakecase": "~4.1.9",
		"@types/node": "~24.9.1",
		"sst": "4.15.2"
	},
	"peerDependencies": {
		"sst": "^4.15.2"
	}
}
