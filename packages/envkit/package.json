{
	"name": "@geekmidas/envkit",
	"version": "1.1.0",
	"private": false,
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./sst": {
			"import": {
				"types": "./dist/sst.d.mts",
				"default": "./dist/sst.mjs"
			},
			"require": {
				"types": "./dist/sst.d.cts",
				"default": "./dist/sst.cjs"
			}
		},
		"./sniffer": {
			"import": {
				"types": "./dist/SnifferEnvironmentParser.d.mts",
				"default": "./dist/SnifferEnvironmentParser.mjs"
			},
			"require": {
				"types": "./dist/SnifferEnvironmentParser.d.cts",
				"default": "./dist/SnifferEnvironmentParser.cjs"
			}
		},
		"./credentials": {
			"import": {
				"types": "./dist/credentials.d.mts",
				"default": "./dist/credentials.mjs"
			},
			"require": {
				"types": "./dist/credentials.d.cts",
				"default": "./dist/credentials.cjs"
			}
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/geekmidas/toolbox"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"dependencies": {
		"lodash.set": "~4.3.2",
		"lodash.get": "~4.4.2",
		"lodash.snakecase": "~4.1.1"
	},
	"peerDependencies": {
		"zod": "~4.1.13"
	},
	"devDependencies": {
		"@types/lodash.get": "~4.4.9",
		"@types/lodash.set": "~4.3.9",
		"@types/lodash.snakecase": "~4.1.9",
		"@types/node": "~24.9.1"
	}
}
